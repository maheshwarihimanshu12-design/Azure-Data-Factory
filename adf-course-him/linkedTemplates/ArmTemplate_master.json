{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-course-him"
		},
		"LinkServiceDataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LinkServiceDataLake'"
		},
		"LinkServiceDataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adfstgdatafactory.dfs.core.windows.net/"
		},
		"linked_git_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"Managertrigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/238e2a08-b386-4c2c-b4f8-b8256e051b64/resourceGroups/RG-ADFCourse/providers/Microsoft.Storage/storageAccounts/adfstgdatafactory"
		},
		"Mantrigger_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/238e2a08-b386-4c2c-b4f8-b8256e051b64/resourceGroups/RG-ADFCourse/providers/Microsoft.Storage/storageAccounts/adfstgdatafactory"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-course-him_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LinkServiceDataLake_accountKey": {
						"value": "[parameters('LinkServiceDataLake_accountKey')]"
					},
					"LinkServiceDataLake_properties_typeProperties_url": {
						"value": "[parameters('LinkServiceDataLake_properties_typeProperties_url')]"
					},
					"linked_git_properties_typeProperties_url": {
						"value": "[parameters('linked_git_properties_typeProperties_url')]"
					},
					"Managertrigger_properties_typeProperties_scope": {
						"value": "[parameters('Managertrigger_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "adf-course-him_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Mantrigger_properties_typeProperties_scope": {
						"value": "[parameters('Mantrigger_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'adf-course-him_ArmTemplate_0')]"
			]
		}
	]
}